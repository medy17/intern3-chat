# App
BETTER_AUTH_SECRET="<generate-a-random-secret>"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/intern3_db"
VITE_BETTER_AUTH_URL="http://localhost:3000"

# Browser
VITE_CONVEX_URL="http://127.0.0.1:3210"
VITE_CONVEX_API_URL="http://127.0.0.1:3210/http"
VITE_POSTHOG_HOST=""
VITE_POSTHOG_KEY=""
VITE_ENABLE_VOICE_INPUT="false"
VITE_ENABLED_INTERNAL_PROVIDERS="openai,google,xai"

# Auth
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# Convex only
ENCRYPTION_KEY="<generate-a-random-secret>"
GOOGLE_INTERNAL_PROVIDER="ai-studio"
GOOGLE_AI_STUDIO_API_KEY="AIza..."
GOOGLE_GENERATIVE_AI_API_KEY=""
GOOGLE_VERTEX_CREDENTIALS_JSON=""
GOOGLE_VERTEX_LOCATION="us-central1"
OPENAI_API_KEY=""
XAI_API_KEY=""
ANTHROPIC_API_KEY=""
GROQ_API_KEY=""
FAL_API_KEY=""
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# S3-compatible storage for Convex R2 component
R2_FORCE_PATH_STYLE="true"
R2_BUCKET="intern3-user-files"
R2_ENDPOINT="http://localhost:9000"
R2_ACCESS_KEY_ID="minioadmin"
R2_SECRET_ACCESS_KEY="minioadmin"

# Optional built-in search providers
FIRECRAWL_API_KEY=""
BRAVE_API_KEY=""
TAVILY_API_KEY=""
SERPER_API_KEY=""

# Notes
# 1. Local infra: `docker compose up -d`
# 2. Initialize auth tables on a fresh database with `bun run auth:push`
# 3. One-time Convex local deployment setup: `bunx convex dev --configure existing --dev-deployment local --once`
# 4. Start Convex locally with `bunx convex dev --local`
# 5. Start the app with `bun run dev`
# 6. Prefer leaving `CONVEX_DEPLOY_KEY` unset in local files to avoid accidental cloud deploy targeting.
