{
    "name": "silkchat",
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "personas:sync-builtins": "node scripts/sync-built-in-personas.mjs",
        "predev": "node scripts/sync-built-in-personas.mjs",
        "dev": "vite dev --port 3000",
        "prebuild": "node scripts/sync-built-in-personas.mjs",
        "test": "vitest run",
        "local:setup": "node scripts/local-setup.mjs",
        "prelocal:dev": "node scripts/sync-built-in-personas.mjs",
        "local:dev": "node scripts/local-dev.mjs",
        "local:infra:up": "docker compose up -d",
        "local:infra:down": "docker compose down",
        "local:convex:configure": "bunx convex dev --configure existing --dev-deployment local --local-force-upgrade --once --codegen disable --typecheck disable",
        "local:convex": "bunx convex dev --local --local-force-upgrade --tail-logs pause-on-deploy --codegen disable --typecheck disable",
        "prelocal:app": "node scripts/sync-built-in-personas.mjs",
        "local:app": "vite dev --port 3000",
        "cloud:dev:push": "node scripts/push-cloud-dev.mjs",
        "build": "vite build",
        "start": "node .output/server/index.mjs",
        "lint": "biome check --write",
        "check-types": "tsc --noEmit",
        "postinstall": "patch-package && node scripts/fix-tanstack-start-plugin-core.mjs && cd node_modules/@convex-dev/r2 && tsc --project ./esm.json && echo '{\"type\": \"module\"}' > dist/esm/package.json",
        "auth:generate": "npx @better-auth/cli generate --output src/database/auth-schema.ts",
        "auth:migrate": "npx drizzle-kit migrate",
        "auth:push": "npx drizzle-kit push",
        "prepare": "husky"
    },
    "keywords": ["better-auth", "tanstack", "vite", "react"],
