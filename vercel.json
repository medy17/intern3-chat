{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "installCommand": "bun install",
    "buildCommand": "bun run build",
    "images": {
        "sizes": [
            324, 384, 403, 405, 420, 432, 461, 480, 506, 540, 576, 608, 720, 759, 788, 810, 864,
            1080
        ],
        "formats": ["image/avif", "image/webp"],
        "minimumCacheTTL": 2678400,
        "remotePatterns": [
            {
                "protocol": "https",
                "hostname": "**.convex.site",
                "pathname": "/**"
            },
            {
                "protocol": "https",
                "hostname": "**.storage.supabase.co",
                "pathname": "/storage/v1/s3/**"
            },
            {
                "protocol": "http",
                "hostname": "127.0.0.1",
                "pathname": "/http/**"
            },
            {
                "protocol": "http",
                "hostname": "localhost",
                "pathname": "/http/**"
            }
        ]
    },
    "headers": [
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ]
}
